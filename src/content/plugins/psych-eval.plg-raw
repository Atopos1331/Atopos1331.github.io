{
    "name": "Psych Eval",
    "description": "A compact emotional monitor with an integrated input field.",
    "entry": {
        "module": "psych-eval",
        "scope": "workspace",
        "mount": "dock"
    },
    "params": {},
    "paramsSchema": [],
    "runtime": {
        "html": [
            "<section class=\"elf-psych-eval\" data-psych>",
            "  <div class=\"elf-psych-eval__topbar\">",
            "    <div class=\"elf-psych-eval__handle\" data-psych-handle>",
            "      <div>",
            "        <div class=\"elf-psych-eval__eyebrow\">PSYCH EVAL</div>",
            "        <div class=\"elf-psych-eval__sub\">Neural Core v3.0</div>",
            "      </div>",
            "      <div class=\"elf-psych-eval__badge\" data-psych-status>OFFLINE</div>",
            "    </div>",
            "    <button class=\"elf-psych-eval__close\" data-psych-close title=\"Terminate\">×</button>",
            "  </div>",
            "  <div class=\"elf-psych-eval__body\">",
            "    <div class=\"elf-psych-eval__display\">",
            "      <div class=\"elf-psych-eval__emoji\" data-psych-emoji>💤</div>",
            "      <div class=\"elf-psych-eval__label\" data-psych-label>HIBERNATING</div>",
            "    </div>",
            "    <div class=\"elf-psych-eval__setup\" data-psych-setup>",
            "      <div class=\"elf-psych-eval__setup-hint\">Requires ~120MB weights.</div>",
            "      <button class=\"elf-psych-eval__btn\" data-psych-load>Initialize Core</button>",
            "      <div class=\"elf-psych-eval__progress-bar\" data-psych-progress-wrap style=\"display: none;\">",
            "        <div class=\"elf-psych-eval__progress-fill\" data-psych-progress></div>",
            "      </div>",
            "    </div>",
            "    <div class=\"elf-psych-eval__hint\" data-psych-hint style=\"display: none;\">Ready for neural input.</div>",
            "    <div class=\"elf-psych-eval__input-wrapper\">",
            "      <span class=\"elf-psych-eval__prompt\" data-psych-prompt>&gt;</span>",
            "      <input type=\"text\" class=\"elf-psych-eval__input\" data-psych-input placeholder=\"Scan mind...\" disabled />",
            "    </div>",
            "  </div>",
            "</section>"
        ],
        "css": [
            ".elf-psych-eval {",
            "  --emotion-color: #475569;",
            "  position: absolute;",
            "  left: 2rem;",
            "  top: 2rem;",
            "  width: min(20rem, calc(100% - 2rem));",
            "  padding: 1.2rem;",
            "  border-radius: 1.2rem;",
            "  border: 1px solid color-mix(in srgb, var(--emotion-color) 50%, rgba(255,255,255,0.2));",
            "  background: linear-gradient(180deg, rgba(2, 6, 23, 0.9), rgba(2, 6, 23, 0.98));",
            "  box-shadow: 0 0 30px color-mix(in srgb, var(--emotion-color) 30%, transparent);",
            "  color: #e2f7ff;",
            "  font-family: \"IBM Plex Mono\", monospace;",
            "  pointer-events: auto;",
            "  user-select: none;",
            "  display: flex;",
            "  flex-direction: column;",
            "  transition: border-color 0.4s ease, box-shadow 0.4s ease;",
            "}",
            ".elf-psych-eval__topbar { display: flex; align-items: flex-start; gap: 0.8rem; margin-bottom: 0.8rem; flex-shrink: 0; }",
            ".elf-psych-eval__handle { flex: 1; display: flex; align-items: center; justify-content: space-between; cursor: grab; }",
            ".elf-psych-eval__eyebrow { font-size: 1rem; font-weight: 800; letter-spacing: 0.15em; color: var(--emotion-color); }",
            ".elf-psych-eval__sub { font-size: 0.75rem; color: rgba(226, 247, 255, 0.5); margin-top: 0.2rem; }",
            ".elf-psych-eval__badge { font-size: 0.75rem; padding: 0.2rem 0.5rem; border-radius: 4px; background: rgba(255,255,255,0.1); font-weight: bold; border: 1px solid rgba(255,255,255,0.1); }",
            ".elf-psych-eval__close { background: transparent; border: none; color: rgba(255,255,255,0.3); font-size: 1.8rem; line-height: 0.8; cursor: pointer; padding: 0; transition: color 0.2s; }",
            ".elf-psych-eval__close:hover { color: #ef4444; }",
            ".elf-psych-eval__body { display: flex; flex-direction: column; flex: 1; }",
            ".elf-psych-eval__display { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; min-height: 7rem; border-radius: 0.8rem; background: rgba(0,0,0,0.4); border: 1px dashed var(--emotion-color); padding: 1rem 0; }",
            ".elf-psych-eval__emoji { font-size: 4rem; margin-bottom: 0.5rem; filter: drop-shadow(0 0 15px var(--emotion-color)); transition: all 0.6s ease; }",
            ".elf-psych-eval__label { font-size: 1.3rem; font-weight: 900; letter-spacing: 0.15em; color: var(--emotion-color); text-transform: uppercase; text-align: center; }",
            ".elf-psych-eval__setup { margin-top: 1rem; display: flex; flex-direction: column; align-items: center; gap: 0.8rem; flex-shrink: 0; }",
            ".elf-psych-eval__setup-hint { font-size: 0.8rem; color: rgba(255,255,255,0.6); }",
            ".elf-psych-eval__btn { background: var(--emotion-color); color: #0f172a; border: none; padding: 0.6rem 1.4rem; border-radius: 6px; font-family: inherit; font-size: 0.9rem; font-weight: 800; cursor: pointer; text-transform: uppercase; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }",
            ".elf-psych-eval__progress-bar { width: 100%; height: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }",
            ".elf-psych-eval__progress-fill { height: 100%; width: 0%; background: var(--emotion-color); transition: width 0.1s linear; }",
            ".elf-psych-eval__hint { font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-top: auto; padding-top: 0.8rem; height: 1.5em; overflow: hidden; text-overflow: ellipsis; flex-shrink: 0; }",
            ".elf-psych-eval__input-wrapper { display: flex; align-items: center; margin-top: 0.5rem; background: rgba(0,0,0,0.5); border: 1px solid color-mix(in srgb, var(--emotion-color) 40%, transparent); border-radius: 0.4rem; padding: 0.6rem 0.8rem; transition: border-color 0.4s ease; flex-shrink: 0; }",
            ".elf-psych-eval__prompt { color: var(--emotion-color); margin-right: 0.6rem; font-size: 1rem; font-weight: bold; }",
            ".elf-psych-eval__input { flex: 1; background: transparent; border: none; color: #fff; font-family: inherit; font-size: 0.95rem; outline: none; width: 100%; }",
            ".elf-psych-eval__input::placeholder { color: rgba(255,255,255,0.2); }"
        ],
        "script": [
            "const panel = api.root.querySelector('[data-psych]');",
            "const handle = api.root.querySelector('[data-psych-handle]');",
            "const closeBtn = api.root.querySelector('[data-psych-close]');",
            "const loadBtn = api.root.querySelector('[data-psych-load]');",
            "const statusNode = api.root.querySelector('[data-psych-status]');",
            "const emojiNode = api.root.querySelector('[data-psych-emoji]');",
            "const labelNode = api.root.querySelector('[data-psych-label]');",
            "const setupNode = api.root.querySelector('[data-psych-setup]');",
            "const progressWrap = api.root.querySelector('[data-psych-progress-wrap]');",
            "const progressFill = api.root.querySelector('[data-psych-progress]');",
            "const hintNode = api.root.querySelector('[data-psych-hint]');",
            "const inputNode = api.root.querySelector('[data-psych-input]');",
            "",
            "if (!panel || !handle || !closeBtn) return;",
            "api.makeDraggable(panel, handle);",
            "",
            "closeBtn.addEventListener('pointerdown', event => {",
            "  event.stopPropagation();",
            "});",
            "closeBtn.addEventListener('click', event => {",
            "  event.preventDefault();",
            "  event.stopPropagation();",
            "  window.dispatchEvent(new CustomEvent('terminal:run', {",
            "    detail: {",
            "      commands: ['plugin ~/plugins/psych-eval.plg'],",
            "    },",
            "  }));",
            "});",
            "",
            "const emotionMap = {",
            "  admiration: { emoji: '🤩', color: '#fde047' }, amusement: { emoji: '😂', color: '#fcd34d' },",
            "  anger: { emoji: '🤬', color: '#ef4444' }, annoyance: { emoji: '😠', color: '#f87171' },",
            "  approval: { emoji: '👍', color: '#a3e635' }, caring: { emoji: '🤗', color: '#fca5a5' },",
            "  confusion: { emoji: '😵‍💫', color: '#c4b5fd' }, curiosity: { emoji: '🤔', color: '#67e8f9' },",
            "  desire: { emoji: '🤤', color: '#fda4af' }, disappointment: { emoji: '😞', color: '#93c5fd' },",
            "  disapproval: { emoji: '👎', color: '#9ca3af' }, disgust: { emoji: '🤢', color: '#84cc16' },",
            "  embarrassment: { emoji: '😳', color: '#f472b6' }, excitement: { emoji: '🎉', color: '#fef08a' },",
            "  fear: { emoji: '😨', color: '#a855f7' }, gratitude: { emoji: '🙏', color: '#fbbf24' },",
            "  grief: { emoji: '😭', color: '#60a5fa' }, joy: { emoji: '😄', color: '#22c55e' },",
            "  love: { emoji: '❤️', color: '#f43f5e' }, nervousness: { emoji: '😬', color: '#c084fc' },",
            "  optimism: { emoji: '🤞', color: '#6ee7b7' }, pride: { emoji: '😌', color: '#fde047' },",
            "  realization: { emoji: '💡', color: '#fef08a' }, relief: { emoji: '😮‍💨', color: '#99f6e4' },",
            "  remorse: { emoji: '😔', color: '#fb7185' }, sadness: { emoji: '😢', color: '#3b82f6' },",
            "  surprise: { emoji: '😲', color: '#fbcfe8' }, neutral: { emoji: '🤖', color: '#94a3b8' }",
            "};",
            "",
            "let classifier = null;",
            "let isAnalyzing = false;",
            "",
            "loadBtn.addEventListener('click', async () => {",
            "  loadBtn.style.display = 'none';",
            "  progressWrap.style.display = 'block';",
            "  statusNode.textContent = 'SYNCING';",
            "  labelNode.textContent = 'LOADING CORE';",
            "  panel.style.setProperty('--emotion-color', '#0ea5e9');",
            "  try {",
            "    const { pipeline, env } = await import('https://cdn.jsdelivr.net/npm/@huggingface/transformers');",
            "    env.allowLocalModels = false;",
            "    classifier = await pipeline('text-classification', 'SamLowe/roberta-base-go_emotions-onnx', {",
            "      progress_callback: (info) => {",
            "        if (info.status === 'progress') {",
            "          progressFill.style.width = `${Math.round(info.progress)}%`;",
            "        }",
            "      }",
            "    });",
            "    setupNode.style.display = 'none';",
            "    hintNode.style.display = 'block';",
            "    statusNode.textContent = 'ONLINE';",
            "    panel.style.setProperty('--emotion-color', '#94a3b8');",
            "    emojiNode.textContent = '🤖';",
            "    labelNode.textContent = 'NEUTRAL';",
            "    inputNode.disabled = false;",
            "    inputNode.focus();",
            "  } catch (e) {",
            "    statusNode.textContent = 'FAULT';",
            "    hintNode.textContent = 'Neural link failure.';",
            "    panel.style.setProperty('--emotion-color', '#ef4444');",
            "  }",
            "});",
            "",
            "const handleInput = async (e) => {",
            "  if (e.key === 'Enter' && !isAnalyzing) {",
            "    const text = e.target.value.trim();",
            "    if (!text || !classifier) return;",
            "    isAnalyzing = true;",
            "    inputNode.disabled = true;",
            "    statusNode.textContent = 'SCANNING';",
            "    try {",
            "      const results = await classifier(text);",
            "      const top = results[0];",
            "      const mapped = emotionMap[top.label] || emotionMap.neutral;",
            "      panel.style.setProperty('--emotion-color', mapped.color);",
            "      emojiNode.textContent = mapped.emoji;",
            "      labelNode.textContent = top.label;",
            "      hintNode.textContent = `Confidence Matrix: ${(top.score * 100).toFixed(1)}%`;",
            "      statusNode.textContent = 'STABLE';",
            "    } finally {",
            "      isAnalyzing = false; inputNode.disabled = false; inputNode.value = ''; inputNode.focus();",
            "    }",
            "  }",
            "};",
            "inputNode.addEventListener('keydown', handleInput);",
            "return () => { inputNode.removeEventListener('keydown', handleInput); };"
        ]
    }
}